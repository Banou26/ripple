# Tells Boost.Build how to invoke Emscripten as a "toolset". Used by build.sh.
# Reference: https://www.boost.org/doc/libs/release/tools/build/doc/html/

import os ;

local EMSDK = [ os.environ EMSDK ] ;

using emscripten
  : 3.1.64
  : "$(EMSDK)/upstream/emscripten/em++"
  : <cxxflags>"-std=c++17 -fPIC -pthread"
    <linkflags>"-pthread"
  ;
